<% layout('/layouts/boilerplate.ejs') -%>

  <body>

    <div class="row offset-2">
      <h3 class="edit-listing-heading mt-2 mb-3">Edit your Listing</h3>

      <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
        <div class="col-8">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="title" class="form-control" value="<%=listing.title%>" />
          </div>

          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="description" class="form-control"><%=listing.title%></textarea>
          </div>

          <div class="mb-3">
            <label for="image-link" class="form-label">Image Link</label>
            <input type="text" name="image-link" class="form-control" value="<%=listing.image%>"
            />
          </div>

          <div class="row">
            <div class="mb-3 col-md-4">
              <label for="price" class="form-label">Price</label>
              <input type="number" name="price" class="form-control" value="<%=listing.price%>" />
            </div>

            <div class="mb-3 col-md-8">
              <label for="location" class="form-label">Location</label>
              <input type="text" name="location" class="form-control" value="<%=listing.location%>" />
            </div>
          </div>

          <div class="mb-3">
            <label for="country" class="form-label">Country</label>
            <input type="text" name="country" class="form-control" value="<%=listing.country%>" />
          </div>
        </div>

        <button class="btn btn-danger edit-btn">Edit</button>
        <br><br>

      </form>

  </body>